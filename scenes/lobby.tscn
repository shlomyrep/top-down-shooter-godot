[gd_scene format=3 uid="uid://lobby001"]

[ext_resource type="Script" path="res://scripts/lobby.gd" id="1_lobby"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_header"]
bg_color = Color(0.05, 0.06, 0.14, 0.97)
border_width_bottom = 2
border_color = Color(0.2, 0.3, 0.55, 0.7)

