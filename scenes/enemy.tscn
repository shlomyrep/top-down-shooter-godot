[sub_resource type="Shader" id="Shader_enemy_outline"]
code = "shader_type canvas_item; uniform vec4 outline_color : source_color = vec4(0.8,0.19,0.19,1.0); uniform float outline_width : hint_range(0.5,4.0) = 1.5; void fragment() { vec4 color = texture(TEXTURE,UV); if(color.a>0.01){COLOR=color;return;} vec2 texel=outline_width/vec2(textureSize(TEXTURE,0)); float a=0.0; a=max(a,texture(TEXTURE,UV+vec2(texel.x,0.0)).a); a=max(a,texture(TEXTURE,UV+vec2(-texel.x,0.0)).a); a=max(a,texture(TEXTURE,UV+vec2(0.0,texel.y)).a); a=max(a,texture(TEXTURE,UV+vec2(0.0,-texel.y)).a); a=max(a,texture(TEXTURE,UV+vec2(texel.x,texel.y)).a); a=max(a,texture(TEXTURE,UV+vec2(-texel.x,texel.y)).a); a=max(a,texture(TEXTURE,UV+vec2(texel.x,-texel.y)).a); a=max(a,texture(TEXTURE,UV+vec2(-texel.x,-texel.y)).a); COLOR=vec4(outline_color.rgb,outline_color.a*a); }"

